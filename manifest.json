{
    "manifest_version": 3,
    "name": "AI Pomodoro",
    "version": "0.3.0",
    "description": "Forced AI-free intervals to build the muscle of thinking without guardrails.",
    "permissions": [
        "storage",
        "webNavigation",
        "alarms",
        "tabs",
        "notifications"
    ],
    "host_permissions": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://www.perplexity.ai/*",
        "*://copilot.microsoft.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Pomodoro"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "blocked.html"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}