{
    "manifest_version": 3,
    "name": "AI Pomodoro",
    "version": "0.1.0",
    "description": "Forced AI-free intervals to build the muscle of thinking without guardrails.",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Pomodoro"
    },
    "background": {
        "service_worker": "background.js"
    }
}